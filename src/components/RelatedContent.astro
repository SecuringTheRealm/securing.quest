---
import type { ResolvedRelated } from '../utils/relatedContent';

export interface Props {
	items: ResolvedRelated[];
	realm?: string;
}

const { items, realm } = Astro.props;
---

{
	items.length > 0 && (
		<section class="related-content stone-card" data-realm={realm} aria-labelledby="go-deeper">
			<h2 id="go-deeper">Go deeper in the realm</h2>
			<ul class="related-content__list">
				{items.map((link: ResolvedRelated) => {
					const external = link.type === 'external';
					return (
						<li>
							<a
								href={link.url}
								target={external ? '_blank' : undefined}
								rel={external ? 'noopener noreferrer' : undefined}
							>
								{link.title}
								{external && (
									<span class="ext-glyph" aria-hidden="true">
										↗
									</span>
								)}
								{external && <span class="sr-only"> (opens in new tab)</span>}
							</a>
						</li>
					);
				})}
			</ul>
		</section>
	)
}

<style>
	.related-content {
		margin-top: var(--space-8);
	}

	.related-content__list {
		list-style: none;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: var(--space-2);
	}

	.ext-glyph {
		margin-left: var(--space-1);
	}
</style>
