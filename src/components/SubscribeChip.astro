---
export interface Props {
	href: string;
	label: string;
	platform: string;
}

const { href, label, platform } = Astro.props;
---

<a
	href={href}
	class="btn-primary btn-sm"
	style="border-radius: var(--radius-full);"
	data-social={platform}
	target="_blank"
	rel="noopener noreferrer"
	aria-label={`${label} (opens in new tab)`}
>
	{label}
</a>
