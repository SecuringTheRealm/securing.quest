---
import type { CollectionEntry } from 'astro:content';
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import AuthorByline from '../../components/AuthorByline.astro';
import Giscus from '../../components/Giscus.astro';
import RelatedContent from '../../components/RelatedContent.astro';
import Webmentions from '../../components/Webmentions.astro';
import Base from '../../layouts/Base.astro';
import { resolveRelated } from '../../utils/relatedContent';

export const getStaticPaths = (async () => {
	const blogEntries = await getCollection('blog', ({ data }: CollectionEntry<'blog'>) => {
		return data.draft !== true;
	});

	return blogEntries.map((entry: CollectionEntry<'blog'>) => ({
		params: { slug: entry.id },
		props: { entry },
	}));
}) satisfies GetStaticPaths;

interface Props {
	entry: CollectionEntry<'blog'>;
}

const { entry } = Astro.props as Props;
const { Content } = await render(entry);
const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const related = resolveRelated(entry.data.relatedContent ?? []);
---

<Base
  title={entry.data.title}
  description={entry.data.description}
  article={true}
  publishDate={entry.data.pubDate}
  tags={entry.data.tags}
>
  <article class="h-entry container" data-realm="library" style="padding: var(--space-16) var(--space-4); max-width: var(--max-width-prose);">
    <a class="u-url" href={canonicalURL} style="display: none;">{entry.data.title}</a>
    <header style="margin-bottom: var(--space-8);">
      <h1 class="p-name" style="margin-bottom: var(--space-4);">{entry.data.title}</h1>
      <time class="dt-published" datetime={entry.data.pubDate.toISOString()} style="font-size: var(--font-size-sm); color: var(--colour-stone-light);">
        {entry.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
      </time>
      <AuthorByline authorId={entry.data.author} />
      {entry.data.tags.length > 0 && (
        <div style="display: flex; gap: var(--space-2); flex-wrap: wrap; margin-top: var(--space-4);">
          {entry.data.tags.map((tag: string) => (
            <a href={`/tags/${tag}/`} class="p-category tag-chip">
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    <div class="e-content prose" style="line-height: var(--line-height-relaxed); font-size: var(--font-size-lg);">
      <Content />
    </div>

    <RelatedContent items={related} realm="library" />

    <Webmentions />

    <Giscus />

    <footer style="margin-top: var(--space-12); padding-top: var(--space-8); border-top: 2px solid var(--colour-gold);">
      <a href="/blog/" class="btn-primary">
        ← Back to Library
      </a>
    </footer>
  </article>
</Base>
