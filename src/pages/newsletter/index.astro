---
import ScrollsIcon from '../../components/ScrollsIcon.astro';
import Base from '../../layouts/Base.astro';
---

<Base title="Arcane Scrolls - Newsletter">
  <div class="container" style="padding: var(--space-16) var(--space-4); max-width: var(--max-width-narrow);">
    <div style="display: flex; flex-direction: column; align-items: center; margin-bottom: var(--space-8);">
      <ScrollsIcon />
      <h1 style="text-align: center; margin-top: var(--space-6); margin-bottom: var(--space-4);">📜 Arcane Scrolls</h1>
      <p style="text-align: center; font-size: var(--font-size-lg);">
        Subscribe to receive updates on our latest quests, technical insights, and adventures in the realm of technology.
      </p>
    </div>

    <div style="background: var(--colour-teal-dark); padding: var(--space-8); border: 2px solid var(--colour-gold); border-radius: var(--radius-outer);">
      <h2 style="margin-bottom: var(--space-4); text-align: center;">Coming Soon!</h2>
      <p style="text-align: center; font-size: var(--font-size-lg); margin-bottom: var(--space-6); line-height: var(--line-height-relaxed);">
        We're crafting our newsletter experience. In the meantime, follow us on your favorite platform to stay updated with our latest adventures!
      </p>

      <h3 style="margin-bottom: var(--space-4); text-align: center; font-size: var(--font-size-base);">What You'll Eventually Receive:</h3>
      <ul style="margin-bottom: var(--space-6); line-height: var(--line-height-relaxed);">
        <li>🎯 <strong>Weekly Quest Updates</strong>: New blog posts, talks, and projects</li>
        <li>🔐 <strong>Security Insights</strong>: Latest threats and defense strategies</li>
        <li>🤖 <strong>AI Adventures</strong>: Updates on LLM deployments and agentic systems</li>
        <li>☁️ <strong>Azure Chronicles</strong>: Cloud architecture patterns and best practices</li>
        <li>🎲 <strong>Behind the Dice</strong>: How we blend tech with tabletop gaming</li>
      </ul>

    </div>

    <section style="margin-top: var(--space-12); text-align: center;">
      <h2 style="margin-bottom: var(--space-4);">Follow Us</h2>
      <p style="margin-bottom: var(--space-6);">
        Join us on your favorite platform to stay updated:
      </p>
      <div style="display: flex; gap: var(--space-4); justify-content: center; flex-wrap: wrap;">
        <a href="https://www.youtube.com/@SecuringTheRealm" target="_blank" rel="noopener noreferrer" class="btn-outline btn-sm" style="border-radius: var(--radius-md);">
          YouTube
        </a>
        <a href="https://github.com/SecuringTheRealm" target="_blank" rel="noopener noreferrer" class="btn-outline btn-sm" style="border-radius: var(--radius-md);">
          GitHub
        </a>
        <a href="https://www.linkedin.com/company/securingtherealm/" target="_blank" rel="noopener noreferrer" class="btn-outline btn-sm" style="border-radius: var(--radius-md);">
          LinkedIn
        </a>
      </div>
    </section>
  </div>
</Base>