---
import type { CollectionEntry } from 'astro:content';
import { getCollection } from 'astro:content';
import MoonIcon from '../../components/MoonIcon.astro';
import Base from '../../layouts/Base.astro';
import { fetchYouTubeShorts } from '../../utils/youtube';

// Fetch shorts from YouTube at build time
const youtubeShorts = await fetchYouTubeShorts();

// Get manual overrides from content collection
const manualOverrides = await getCollection('shorts');

// Create a map of overrides by youtubeId
const overrideMap = new Map<string, CollectionEntry<'shorts'>>();
manualOverrides.forEach((override: CollectionEntry<'shorts'>) => {
	overrideMap.set(override.data.youtubeId, override);
});

// Apply overrides
const mergedShorts = youtubeShorts.map((short) => {
	const override = overrideMap.get(short.id);
	if (override) {
		return {
			...short,
			title: override.data.title || short.title,
			tags: override.data.tags ? [...new Set([...short.tags, ...override.data.tags])] : short.tags,
			relatedContent: override.data.relatedContent
				? [
						...short.relatedContent,
						...override.data.relatedContent.map(
							(rc: {
								type: 'blog' | 'talk' | 'project' | 'external';
								slug: string;
								title?: string;
							}) => ({
								type: rc.type,
								url:
									rc.type === 'external'
										? rc.slug
										: `/${rc.type === 'talk' ? 'talks' : rc.type === 'project' ? 'forge' : rc.type}/${rc.slug}/`,
								title: rc.title || `Related ${rc.type}`,
							})
						),
					]
				: short.relatedContent,
		};
	}
	return short;
});

// Sort by pubDate descending (newest first)
const sortedShorts = mergedShorts.sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());
---

<Base title="Moon - Shorts">
  <div class="container" style="padding: var(--space-16) var(--space-4);">
    <div style="display: flex; flex-direction: column; align-items: center; margin-bottom: var(--space-12);">
      <MoonIcon />
      <h1 style="text-align: center; margin-top: var(--space-6); margin-bottom: var(--space-4);">🌙 The Moon</h1>
      <p style="text-align: center; font-size: var(--font-size-lg); max-width: 700px; margin: 0 auto;">
        Quick glimpses into the realm - bite-sized adventures in security, AI, and beyond.
      </p>
    </div>

    <div class="shorts-grid">
      {sortedShorts.map((short) => (
        <article class="short-card">
          <a href={short.videoUrl} target="_blank" rel="noopener noreferrer" class="short-thumbnail-link" aria-label={`Watch ${short.title} on YouTube`}>
            <img
              src={short.thumbnailUrl}
              alt={short.title}
              loading="lazy"
              class="short-thumbnail"
            />
            <span class="play-icon" aria-hidden="true">&#9654;</span>
          </a>
          <div class="short-content">
            <h2 class="short-title">
              <a href={short.videoUrl} target="_blank" rel="noopener noreferrer">
                {short.title}
              </a>
            </h2>
            <p class="short-date">
              {short.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </p>
            {short.relatedContent.length > 0 && (
              <div class="short-related">
                <span class="related-label">Related:</span>
                {short.relatedContent.map((link) => (
                  <a href={link.url} class="related-link">
                    {link.title}
                  </a>
                ))}
              </div>
            )}
            {short.tags.length > 0 && (
              <div class="short-tags">
                {short.tags.map((tag: string) => (
                  <span class="short-tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>

  <script is:inline>
    document.querySelectorAll('.short-card a[target="_blank"]').forEach(function (link) {
      link.addEventListener('click', function () {
        if (typeof plausible !== 'undefined') {
          var card = link.closest('.short-card');
          var title = card ? (card.querySelector('.short-title') || {}).textContent || 'Unknown' : 'Unknown';
          plausible('Short Watch', { props: { title: title.trim() } });
        }
      });
    });
  </script>
</Base>

<style>
  .shorts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--space-6);
    max-width: 1200px;
    margin: 0 auto;
  }

  .short-card {
    background: var(--colour-teal-dark);
    border: 2px solid var(--colour-gold);
    border-radius: var(--radius-outer);
    overflow: hidden;
    transition: transform var(--transition-base);
  }

  .short-card:hover {
    transform: translateY(-4px);
  }

  .short-thumbnail-link {
    display: block;
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
    background: black;
  }

  .short-thumbnail {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .play-icon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: var(--font-size-2xl);
    color: var(--colour-parchment);
    background: rgba(0, 0, 0, 0.6);
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-full);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .short-thumbnail-link:hover .play-icon,
  .short-thumbnail-link:focus .play-icon {
    opacity: 1;
  }

  .short-content {
    padding: var(--space-4);
  }

  .short-title {
    font-size: var(--font-size-base);
    margin: 0 0 var(--space-2) 0;
    line-height: var(--line-height-snug);
  }

  .short-title a {
    color: var(--colour-gold);
    text-decoration: none;
  }

  .short-title a:hover {
    text-decoration: underline;
  }

  .short-date {
    font-size: var(--font-size-xs);
    color: var(--colour-stone-light);
    margin: 0 0 var(--space-3) 0;
  }

  .short-related {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    margin-bottom: var(--space-3);
    font-size: var(--font-size-sm);
  }

  .related-label {
    color: var(--colour-stone-light);
    font-size: var(--font-size-xs);
  }

  .related-link {
    color: var(--colour-parchment);
    font-size: var(--font-size-xs);
    text-decoration: underline;
    text-decoration-color: var(--colour-stone-light);
  }

  .related-link:hover {
    color: var(--colour-gold);
  }

  .short-tags {
    display: flex;
    gap: var(--space-1);
    flex-wrap: wrap;
  }

  .short-tag {
    font-size: var(--font-size-xs);
    padding: var(--space-1) var(--space-2);
    background: var(--colour-gold);
    color: var(--colour-ink);
    border-radius: var(--radius-full);
  }

  @media (prefers-reduced-motion: reduce) {
    .short-card:hover {
      transform: none;
    }

    .play-icon {
      opacity: 1;
      transition: none;
    }
  }
</style>
